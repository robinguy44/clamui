#: src/cli/scheduled_scan.py:105
msgid "ClamUI Scheduled Scan - Headless antivirus scanning"
msgstr "ClamUI 定期扫描——无前端的防病毒扫描"

#: src/cli/scheduled_scan.py:108
#, python-format
msgid ""
"\n"
"Examples:\n"
"  %(prog)s                                    # Use settings from config\n"
"  %(prog)s --target /home/user/Documents      # Scan specific directory\n"
"  %(prog)s --skip-on-battery --auto-quarantine # Skip on battery, quarantine "
"threats\n"
msgstr ""
"\n"
"用法示例:\n"
"  %(prog)s                                    # 使用配置中的设置\n"
"  %(prog)s --target /home/user/Documents      # 扫描指定的目录\n"
"  %(prog)s --skip-on-battery --auto-quarantine # 电池供电时跳过，自动隔离威胁\n"

