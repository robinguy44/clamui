---
const tabs = [
  {
    id: "flatpak",
    label: "Flatpak",
    sub: "Recommended",
    desc: "Works on every distro. Sandboxed. Auto-updates via Flathub.",
    code: "flatpak install flathub io.github.linx_systems.ClamUI\nflatpak run io.github.linx_systems.ClamUI",
  },
  {
    id: "deb",
    label: "Debian / Ubuntu",
    sub: ".deb",
    desc: "Native packages for Debian 12+, Ubuntu 22.04+, Linux Mint, Pop!_OS.",
    code: "# Download the latest .deb from GitHub Releases, then:\nsudo apt install ./clamui_0.2.0_amd64.deb",
  },
  {
    id: "appimage",
    label: "AppImage",
    sub: "Portable",
    desc: "Single-file bundle with GTK4 + Python. Requires ClamAV on host.",
    code: "chmod +x ClamUI-0.2.0-x86_64.AppImage\n./ClamUI-0.2.0-x86_64.AppImage",
  },
  {
    id: "source",
    label: "From source",
    sub: "uv",
    desc: "Python 3.11+, GTK4, libadwaita, uv. See docs/DEVELOPMENT.md.",
    code: "git clone https://github.com/linx-systems/clamui.git\ncd clamui\nuv sync --dev\nuv run clamui",
  },
];
---

<section id="install" class="container-tight py-20 sm:py-28">
  <div class="max-w-2xl">
    <span class="eyebrow">Get it running</span>
    <h2 class="mt-3 section-title">Install</h2>
    <p class="mt-4 lede">
      Pick the channel your distro uses. ClamUI itself is the UI — it'll detect ClamAV on
      your system, tell you if it's missing, and print the exact command to fix it.
    </p>
  </div>

  <div
    class="mt-10 rounded-2xl border hairline bg-white/[0.02] overflow-hidden"
    data-install-tabs
  >
    <div
      role="tablist"
      aria-label="Install method"
      class="flex overflow-x-auto border-b hairline"
    >
      {
        tabs.map((t, i) => (
          <button
            role="tab"
            type="button"
            id={`tab-${t.id}`}
            aria-controls={`panel-${t.id}`}
            aria-selected={i === 0 ? "true" : "false"}
            data-target={t.id}
            class="relative px-5 py-4 text-sm whitespace-nowrap text-white/60 hover:text-white focus-visible:outline-none focus-visible:bg-white/[0.04] data-[active=true]:text-white"
            data-active={i === 0 ? "true" : "false"}
          >
            <span class="font-medium">{t.label}</span>
            <span class="ml-2 text-[10px] font-mono uppercase tracking-wider text-white/35">
              {t.sub}
            </span>
            <span
              class="absolute left-4 right-4 bottom-0 h-px bg-clam-sage opacity-0 data-[active=true]:opacity-100"
              data-active={i === 0 ? "true" : "false"}
            />
          </button>
        ))
      }
    </div>

    {
      tabs.map((t, i) => (
        <div
          role="tabpanel"
          id={`panel-${t.id}`}
          aria-labelledby={`tab-${t.id}`}
          data-panel={t.id}
          hidden={i !== 0}
          class="p-5 sm:p-7"
        >
          <p class="text-sm text-white/70 mb-4">{t.desc}</p>
          <div class="relative group">
            <pre
              class="term term-body !m-0 whitespace-pre overflow-x-auto text-[13px] leading-relaxed"
            ><code>{t.code}</code></pre>
            <button
              type="button"
              data-copy
              data-copy-text={t.code}
              class="absolute top-3 right-3 text-[11px] font-mono uppercase tracking-wider px-2.5 py-1.5 rounded-md border border-white/10 bg-black/40 text-white/70 hover:text-white hover:bg-black/60 transition"
            >
              Copy
            </button>
          </div>
        </div>
      ))
    }
  </div>

  <div class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-white/50">
    <a
      href="https://github.com/linx-systems/clamui/releases"
      rel="noopener"
      class="inline-flex items-center gap-1.5 text-clam-sage hover:text-white transition-colors"
    >
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20.59 13.41 13.42 20.58a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
        <line x1="7" y1="7" x2="7.01" y2="7"></line>
      </svg>
      <span>All releases · <span class="font-mono">.deb</span> · <span class="font-mono">AppImage</span> · checksums</span>
    </a>
    <a
      href="https://github.com/linx-systems/clamui/blob/master/docs/INSTALL.md"
      rel="noopener"
      class="hover:text-white transition-colors"
    >
      Install notes
    </a>
    <a
      href="https://github.com/linx-systems/clamui/blob/master/docs/SIGNING.md"
      rel="noopener"
      class="hover:text-white transition-colors"
    >
      Signing policy
    </a>
  </div>

  <details class="mt-6 group rounded-xl border hairline bg-white/[0.02] open:bg-white/[0.03]">
    <summary
      class="flex items-center gap-3 cursor-pointer list-none px-5 py-4 sm:px-6"
    >
      <span class="grid place-items-center w-8 h-8 rounded-lg bg-clam-forest/15 border border-clam-forest/25 text-clam-sage shrink-0">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
          <path d="m9 12 2 2 4-4"></path>
        </svg>
      </span>
      <div class="flex-1">
        <div class="font-medium text-white">Verify package integrity</div>
        <div class="text-xs text-white/55 mt-0.5">
          Confirm your download is genuine before trusting it. GPG signatures for <span class="font-mono">.deb</span>, embedded signatures for AppImage.
        </div>
      </div>
      <svg
        class="w-4 h-4 text-white/40 transition-transform group-open:rotate-180 shrink-0"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="m6 9 6 6 6-6"></path>
      </svg>
    </summary>

    <div class="px-5 pb-6 sm:px-6 space-y-6 border-t hairline pt-5">
      <div>
        <h4 class="text-sm font-semibold text-white flex items-center gap-2">
          <span class="text-[10px] font-mono uppercase tracking-wider text-white/40 border border-white/10 rounded px-1.5 py-0.5">.deb</span>
          Debian / Ubuntu — GPG signature
        </h4>
        <p class="text-sm text-white/65 mt-2">
          Import the project's public key once, then verify each download with <span class="font-mono text-white/80">dpkg-sig</span>.
        </p>
        <div class="relative mt-3 group">
          <pre class="term term-body !m-0 whitespace-pre overflow-x-auto text-[13px] leading-relaxed"><code># Import the signing key (one-time)
curl -fsSL https://raw.githubusercontent.com/linx-systems/clamui/master/signing-key.asc \
  | gpg --import

# Verify — expect: GOODSIG _gpgbuilder &lt;fingerprint&gt;
dpkg-sig --verify clamui_*.deb</code></pre>
          <button
            type="button"
            data-copy
            data-copy-text={`curl -fsSL https://raw.githubusercontent.com/linx-systems/clamui/master/signing-key.asc | gpg --import\ndpkg-sig --verify clamui_*.deb`}
            class="absolute top-3 right-3 text-[11px] font-mono uppercase tracking-wider px-2.5 py-1.5 rounded-md border border-white/10 bg-black/40 text-white/70 hover:text-white hover:bg-black/60 transition"
          >
            Copy
          </button>
        </div>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-white flex items-center gap-2">
          <span class="text-[10px] font-mono uppercase tracking-wider text-white/40 border border-white/10 rounded px-1.5 py-0.5">AppImage</span>
          Embedded signature
        </h4>
        <p class="text-sm text-white/65 mt-2">
          AppImages carry the signature inside the bundle. A quick check prints key info; the AppImageKit validator does a full verification.
        </p>
        <div class="relative mt-3 group">
          <pre class="term term-body !m-0 whitespace-pre overflow-x-auto text-[13px] leading-relaxed"><code># Quick check — prints signer info
./ClamUI-*.AppImage --appimage-signature

# Full validation
wget https://github.com/AppImage/AppImageKit/releases/download/continuous/validate-x86_64.AppImage
chmod +x validate-x86_64.AppImage
./validate-x86_64.AppImage ./ClamUI-*.AppImage</code></pre>
          <button
            type="button"
            data-copy
            data-copy-text={`./ClamUI-*.AppImage --appimage-signature\nwget https://github.com/AppImage/AppImageKit/releases/download/continuous/validate-x86_64.AppImage\nchmod +x validate-x86_64.AppImage\n./validate-x86_64.AppImage ./ClamUI-*.AppImage`}
            class="absolute top-3 right-3 text-[11px] font-mono uppercase tracking-wider px-2.5 py-1.5 rounded-md border border-white/10 bg-black/40 text-white/70 hover:text-white hover:bg-black/60 transition"
          >
            Copy
          </button>
        </div>
      </div>

      <div class="flex items-start gap-3 text-sm text-white/60 border hairline rounded-lg p-3.5 bg-black/20">
        <svg class="w-4 h-4 mt-0.5 text-clam-amber shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="8" x2="12" y2="13"></line>
          <line x1="12" y1="16" x2="12.01" y2="16"></line>
        </svg>
        <p>
          <span class="text-white/85 font-medium">Flatpak</span> needs no manual step —
          Flathub verifies signatures automatically during install.
          <span class="text-white/85 font-medium">Source builds</span> are verified by their Git commit; tagged releases are signed, so <span class="font-mono">git tag -v v0.2.0</span> confirms authorship.
        </p>
      </div>
    </div>
  </details>
</section>

<script>
  const bind = () => {
    document.querySelectorAll("[data-install-tabs]").forEach((root) => {
      if ((root as any).dataset.bound) return;
      (root as any).dataset.bound = "1";

      const tabs = root.querySelectorAll<HTMLButtonElement>("[role=tab]");
      const panels = root.querySelectorAll<HTMLElement>("[role=tabpanel]");

      const select = (id: string) => {
        tabs.forEach((t) => {
          const active = t.dataset.target === id;
          t.setAttribute("aria-selected", active ? "true" : "false");
          t.dataset.active = active ? "true" : "false";
          const underline = t.querySelector<HTMLElement>("[data-active]");
          if (underline) underline.dataset.active = active ? "true" : "false";
        });
        panels.forEach((p) => {
          p.hidden = p.dataset.panel !== id;
        });
      };

      tabs.forEach((t) => {
        t.addEventListener("click", () => t.dataset.target && select(t.dataset.target));
      });

      root.querySelectorAll<HTMLButtonElement>("[data-copy]").forEach((btn) => {
        btn.addEventListener("click", async () => {
          const text = btn.dataset.copyText || "";
          try {
            await navigator.clipboard.writeText(text);
            const original = btn.textContent;
            btn.textContent = "Copied";
            btn.classList.add("text-clam-sage", "border-clam-sage/40");
            setTimeout(() => {
              btn.textContent = original;
              btn.classList.remove("text-clam-sage", "border-clam-sage/40");
            }, 1400);
          } catch (_) {
            btn.textContent = "Select + copy";
          }
        });
      });
    });
  };
  bind();
  document.addEventListener("astro:page-load", bind);
</script>
